{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowKmsDecryptForSignerMaterial",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:DescribeKey"
      ],
      "Resource": "arn:aws:kms:us-east-1:123456789012:key/replace-with-key-id",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "lambda.us-east-1.amazonaws.com"
        }
      }
    },
    {
      "Sid": "AllowCloudWatchLogging",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}