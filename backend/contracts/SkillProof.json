{
  "abi": [
    {
      "type": "event",
      "name": "CredentialIssued",
      "anonymous": false,
      "inputs": [
        { "name": "credentialId", "type": "uint256", "indexed": true },
        { "name": "student", "type": "address", "indexed": true },
        { "name": "issuer", "type": "address", "indexed": true },
        { "name": "credentialHash", "type": "bytes32", "indexed": false },
        { "name": "issuedAt", "type": "uint64", "indexed": false }
      ]
    },
    {
      "type": "event",
      "name": "CredentialRevoked",
      "anonymous": false,
      "inputs": [
        { "name": "credentialId", "type": "uint256", "indexed": true },
        { "name": "revokedBy", "type": "address", "indexed": true },
        { "name": "credentialHash", "type": "bytes32", "indexed": false },
        { "name": "revokedAt", "type": "uint64", "indexed": false }
      ]
    },
    {
      "type": "function",
      "name": "issueCredential",
      "stateMutability": "nonpayable",
      "inputs": [
        { "name": "student", "type": "address" },
        { "name": "credentialHash", "type": "bytes32" }
      ],
      "outputs": [{ "name": "credentialId", "type": "uint256" }]
    },
    {
      "type": "function",
      "name": "revokeCredential",
      "stateMutability": "nonpayable",
      "inputs": [{ "name": "credentialId", "type": "uint256" }],
      "outputs": []
    },
    {
      "type": "function",
      "name": "verifyCredential",
      "stateMutability": "view",
      "inputs": [{ "name": "credentialHash", "type": "bytes32" }],
      "outputs": [{ "name": "isValid", "type": "bool" }]
    },
    {
      "type": "function",
      "name": "getCredentialIdByHash",
      "stateMutability": "view",
      "inputs": [{ "name": "credentialHash", "type": "bytes32" }],
      "outputs": [{ "name": "credentialId", "type": "uint256" }]
    },
    {
      "type": "function",
      "name": "getCredentialById",
      "stateMutability": "view",
      "inputs": [{ "name": "credentialId", "type": "uint256" }],
      "outputs": [
        {
          "name": "credential",
          "type": "tuple",
          "components": [
            { "name": "credentialId", "type": "uint256" },
            { "name": "credentialHash", "type": "bytes32" },
            { "name": "student", "type": "address" },
            { "name": "issuer", "type": "address" },
            { "name": "issuedAt", "type": "uint64" },
            { "name": "revoked", "type": "bool" }
          ]
        }
      ]
    }
  ]
}
