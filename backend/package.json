{
  "name": "backend",
  "version": "1.0.0",
  "description": "Vindicate production backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "test": "node --test \"test/**/*.test.js\"",
    "build": "npm run prisma:validate && npm run prisma:generate",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "keywords": [
    "express",
    "security",
    "web3",
    "backend"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@sentry/node": "^8.40.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ipfs-http-client": "^60.0.1",
    "jsonwebtoken": "^9.0.2",
    "multiformats": "^13.3.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "siwe": "^3.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.1",
    "globals": "^15.14.0",
    "prisma": "^6.4.1"
  }
}
